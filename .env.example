# SteamPulse — Docker environment variables
#
# Two ways to configure SteamPulse in Docker:
#
# A) Environment variables (this file) — simplest for Steam-only setups.
#    cp .env.example .env  and fill in STEAM_API_KEY + STEAM_ID at minimum.
#    The container generates a config.toml from these vars at startup.
#
# B) Mounted config file — recommended when you also use Epic Games or Twitch.
#    Run  steam-setup  on a machine with SteamPulse installed; copy the
#    resulting config.toml next to docker-compose.yml and uncomment the
#    volume line in docker-compose.yml.  When a config file is mounted,
#    the credential variables below (STEAM_*, EPIC_*, TWITCH_*) are ignored.

# ---------------------------------------------------------------------------
# Required (option A — ignored when a config.toml is mounted)
# ---------------------------------------------------------------------------
STEAM_API_KEY=your_steam_api_key_here
STEAM_ID=76561198000000000

# ---------------------------------------------------------------------------
# Schedule
# ---------------------------------------------------------------------------
# How often to refresh the library (hours). Default: 4
INTERVAL_HOURS=4

# ---------------------------------------------------------------------------
# Web server
# ---------------------------------------------------------------------------
# Host port mapped to nginx port 80. Default: 8080
HOST_PORT=8080

# ---------------------------------------------------------------------------
# Fetch options
# ---------------------------------------------------------------------------
# Interface language: en or fr. Default: en
SP_LANG=en
# Number of parallel fetch threads. Default: 4
WORKERS=4
# Re-fetch news for games whose cached news is older than N hours. Default: 24
NEWS_AGE=24
# Set to "true" to re-fetch everything, ignoring cache on every run. Default: false
REFRESH=false

# ---------------------------------------------------------------------------
# Epic Games (optional — option A only; option B: put these in config.toml)
# ---------------------------------------------------------------------------
# Obtain refresh_token + account_id by running "steam-setup" once locally,
# then copying the values from ~/.config/steampulse/config.toml.
# EPIC_REFRESH_TOKEN=
# EPIC_ACCOUNT_ID=

# ---------------------------------------------------------------------------
# Twitch / IGDB (optional — option A only; option B: put these in config.toml)
# ---------------------------------------------------------------------------
# TWITCH_CLIENT_ID=
# TWITCH_CLIENT_SECRET=
